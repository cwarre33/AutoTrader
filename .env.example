# === OpenClaw Gateway ===
OPENCLAW_GATEWAY_TOKEN=generate-a-random-token-here

# === Alpaca Paper Trading ===
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
# Simulated balance (0 = use full account). Default in docker-compose: 100 for $100 live-style testing.
# SIMULATED_BALANCE=100
# GATEWAY_MODE=live enables PDT (3 day trades / 5 days) and live safeguards. Default in docker-compose: live.
# GATEWAY_MODE=live

# === Ollama (runs on your laptop) ===
# Default: http://host.docker.internal:11434 (Docker accessing host)
# Change if Ollama runs on a different machine
OLLAMA_HOST=http://host.docker.internal:11434

# === OpenAI (fallback if HuggingFace/Ollama fails) ===
OPENAI_API_KEY=your_openai_api_key

# === Discord ===
DISCORD_BOT_TOKEN=your_discord_bot_token
# Optional: Webhook fallbacks if bot API fails (403/1010 in Docker)
# DISCORD_DASHBOARD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_TRADES_WEBHOOK_URL=https://discord.com/api/webhooks/...

# === Optional: OpenClaw image override ===
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
# OPENCLAW_GATEWAY_PORT=18789
